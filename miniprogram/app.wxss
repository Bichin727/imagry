page {
  background: #16213e;
  color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.btn-primary {
  background: linear-gradient(135deg, #e94560, #ff6b6b);
  color: #fff;
  border-radius: 999rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-weight: 600;
}

.card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
}
