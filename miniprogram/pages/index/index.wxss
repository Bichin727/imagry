.hero { text-align: center; margin-top: 80rpx; }
.title { font-size: 44rpx; font-weight: 700; display: block; margin-bottom: 16rpx; }
.subtitle { font-size: 26rpx; opacity: 0.75; display: block; margin-bottom: 48rpx; }
.label { font-size: 28rpx; opacity: 0.8; display: block; margin-bottom: 24rpx; }
.scenes { display: flex; gap: 16rpx; flex-wrap: wrap; }
.scene {
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.1);
  font-size: 28rpx;
}
.scene.active { background: #e94560; }
