.preview, .placeholder {
  width: 100%;
  height: 480rpx;
  border-radius: 16rpx;
  background: rgba(0,0,0,0.2);
}
.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.5);
}
.actions { padding: 0 24rpx; display: flex; flex-direction: column; gap: 24rpx; }
.loading { text-align: center; margin-top: 32rpx; opacity: 0.8; }
